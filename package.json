{
  "name": "bigfish-compass",
  "version": "0.1.0",
  "private": true,
  "description": "Career Guidance Platform for Teens (14-18) - BigFish Compass MVP",
  "workspaces": [
    "packages/*",
    "bigfish-backend",
    "bigfish-front"
  ],
  "scripts": {
    "dev": "npm run dev --workspaces --if-present",
    "dev:backend": "npm run dev -w bigfish-backend",
    "dev:frontend": "npm --prefix bigfish-front run dev",
    "build": "npm run build --workspaces --if-present",
    "build:backend": "npm run build -w bigfish-backend",
    "build:frontend": "npm --prefix bigfish-front run build",
    "test": "npm run test --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "prisma:generate": "npm run prisma:generate -w bigfish-backend",
    "prisma:migrate": "npm run prisma:migrate -w bigfish-backend",
    "db:seed": "npm run db:seed -w bigfish-backend",
    "clean": "rimraf node_modules packages/*/node_modules bigfish-backend/node_modules bigfish-front/node_modules dist"
  },
  "devDependencies": {
    "rimraf": "^5.0.5",
    "typescript": "^5.6.2"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {}
}